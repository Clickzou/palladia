# Supabase — projet Hôtel Palladia
# Copier ce fichier en .env.local (ignoré par git) et remplir les valeurs.
# Tableau de bord Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé de service : NE JAMAIS l'exposer côté client ni la committer.
# Utilisée uniquement par les scripts d'import (scripts/import-articles.mjs).
SUPABASE_SERVICE_ROLE_KEY=

# Resend — notifications des formulaires
# https://resend.com > API Keys. La cle reste dans .env.local, jamais commitee.
RESEND_API_KEY=

# Expediteur. Le domaine doit etre verifie dans Resend (Domains > Add Domain,
# puis les enregistrements DNS chez OVH). Sans domaine verifie, Resend
# n'accepte d'ecrire qu'au proprietaire du compte.
RESEND_FROM="Hôtel Palladia <site@hotelpalladia.com>"

# Google Analytics 4 — identifiant de mesure du flux, de la forme G-XXXXXXXXXX.
# Analytics > Admin > Flux de donnees > flux Web. Public : il figure en clair
# dans le code source des pages. Sans lui, aucune mesure n'est chargee.
NEXT_PUBLIC_GA_ID=

# Deroutement des notifications, pour essayer les formulaires sans ecrire a
# l'hotel. A LAISSER VIDE EN PRODUCTION : un deroutement oublie detournerait
# les demandes reelles. Tant que le domaine n'est pas verifie chez Resend,
# seule l'adresse du proprietaire du compte est acceptee.
COURRIEL_TEST=

# Traduction automatique des menus du restaurant, par l'API Claude.
# https://console.anthropic.com > API Keys. Cote serveur uniquement : sans
# elle, l'espace d'administration fonctionne mais le bouton Traduire echoue.
ANTHROPIC_API_KEY=
